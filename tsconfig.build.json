{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "allowArbitraryExtensions": true
  },
  "include": ["**/*.ts", "**/*.tsx", "css.d.ts", "react-ui.d.ts", "third-party.d.ts"],
  "exclude": ["dist", "node_modules"]
}
